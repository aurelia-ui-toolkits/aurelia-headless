{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "ES2022",
    "lib": ["esnext", "dom"],
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@aurelia-headless/components": ["../components/src"]
    }
  },
  "include": ["src"]
}
