{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "ES2022",
    "lib": [
      "esnext",
      "dom"
    ],
    "outDir": "./dist",
    "declarationDir": "./dist/types",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "strictNullChecks": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitHelpers": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "inlineSources": true,
    "newLine": "lf",
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ]
}
